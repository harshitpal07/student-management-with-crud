<body>

  <div class="stars"></div>
  <div class="stars2"></div>
  <div class="stars3"></div>

  <div class="container">
    <div class="alert bg-success my-3">
      <h4 class="text-center text-white">Add New Student</h4>
    </div>
  </div>

  <div class="container">
    <div class="row">
      <div class="col"></div>
      <div class="col-12 col-md-8 col-lg-6">
        <div class="form-card">
          <form action="/add/student" method="post" id="studentForm" novalidate>
            <div class="field-group">
              <label class="form-label">Roll No</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-hash"></i></span>
                <input type="number" class="form-control" placeholder="enter roll no" name="RollNo" required min="1">
              </div>
              <div class="invalid-feedback">Roll no is required and must be positive.</div>
            </div>

            <div class="field-group">
              <label class="form-label">Name</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input type="text" class="form-control" placeholder="enter name" name="Name" required pattern="[A-Za-z ]{2,50}">
              </div>
              <div class="invalid-feedback">Enter a valid name (letters only).</div>
            </div>

            <div class="field-group">
              <label class="form-label">Father Name</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person-badge"></i></span>
                <input type="text" class="form-control" placeholder="Father name" name="FatherName" required pattern="[A-Za-z ]{2,50}">
              </div>
              <div class="invalid-feedback">Enter a valid father's name (letters only).</div>
            </div>

            <div class="field-group">
              <label class="form-label">Aadhar Number</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-credit-card-2-front"></i></span>
                <input type="number" class="form-control" placeholder="enter aadhar number" name="AadharCardNumber" required pattern="[0-9]{12}" title="12 digit Aadhar number">
              </div>
              <div class="invalid-feedback">Aadhar number must be exactly 12 digits.</div>
            </div>

            <div class="field-group">
              <label class="form-label">Mobile Number</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                <input type="number" class="form-control" placeholder="enter mobile number" name="MobileNo" required pattern="[0-9]{10}" title="10 digit mobile number">
              </div>
              <div class="invalid-feedback">Mobile number must be exactly 10 digits.</div>
            </div>

            <input type="submit" class="btn btn-success" value="Add Student">
          </form>
        </div>
      </div>
      <div class="col"></div>
    </div>
  </div>

  <script>
    const form = document.getElementById('studentForm');
    const rules = {
      RollNo: v => v.trim() !== '' && Number(v) > 0,
      Name: v => /^[A-Za-z ]{2,50}$/.test(v.trim()),
      FatherName: v => /^[A-Za-z ]{2,50}$/.test(v.trim()),
      AadharCardNumber: v => /^[0-9]{12}$/.test(v.trim()),
      MobileNo: v => /^[0-9]{10}$/.test(v.trim())
    };

    function validateField(input){
      const isValid = rules[input.name](input.value);
      input.classList.toggle('is-invalid', !isValid);
      input.classList.toggle('is-valid', isValid);
      const feedback = input.closest('.field-group').querySelector('.invalid-feedback');
      feedback.classList.toggle('show', !isValid);
      return isValid;
    }

    Object.keys(rules).forEach(name => {
      const input = form.querySelector(`[name="${name}"]`);
      input.addEventListener('input', () => validateField(input));
      input.addEventListener('blur', () => validateField(input));
    });

    form.addEventListener('submit', function(e){
      let allValid = true;
      Object.keys(rules).forEach(name => {
        const input = form.querySelector(`[name="${name}"]`);
        if(!validateField(input)) allValid = false;
      });
      if(!allValid) e.preventDefault();
    });
  </script>

</body>
